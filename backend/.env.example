# Copy this file to .env and fill in your actual AWS credentials
# DO NOT commit the .env file to GitHub!

# AWS Account Credentials (from IAM)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Amazon S3 Bucket for Scan Reports
AWS_S3_BUCKET_NAME=your_s3_bucket_name_here

# Amazon RDS MySQL Database Connection URL
# Format: mysql+pymysql://username:password@rds-endpoint-url:3306/dbname
DATABASE_URL=
